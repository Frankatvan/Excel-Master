{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["sfo1"],
  "outputDirectory": ".next",
  "functions": {
    "src/pages/api/audit_sync.ts": {
      "maxDuration": 60,
      "regions": ["sfo1"]
    },
    "src/pages/api/projects/action.ts": {
      "maxDuration": 60,
      "regions": ["sfo1"]
    },
    "api/formula_sync.py": {
      "maxDuration": 60,
      "regions": ["sfo1"]
    },
    "api/project_bootstrap.py": {
      "maxDuration": 60,
      "regions": ["sfo1"]
    },
    "api/external_import_worker.py": {
      "maxDuration": 300,
      "regions": ["sfo1"]
    },
    "api/internal/reclassify_job.py": {
      "maxDuration": 60,
      "regions": ["sfo1"]
    }
  }
}
